{
  "name": "crftersvector-pro2",
  "private": true,
  "version": "1.0.6",
  "type": "module",
  "main": "main.cjs",
  "scripts": {
    "dev": "vite --port=3000 --host=0.0.0.0",
    "build": "vite build",
    "preview": "vite preview",
    "clean": "rm -rf dist",
    "lint": "tsc --noEmit",
    "electron:dev": "electron .",
    "electron:build": "npm run build && electron-builder",
    "electron:build:win": "npm run build && electron-builder --win nsis",
    "electron:build:mac": "npm run build && electron-builder --mac dmg",
    "electron:build:linux": "npm run build && electron-builder --linux AppImage"
  },
  "build": {
    "appId": "com.crafters.vectorpro",
    "productName": "Crafters Vector Pro",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "main.cjs",
      "icon.png"
    ],
    "publish": [
      {
        "provider": "github",
        "owner": "bobguffie",
        "repo": "CrftersVector-Pro2"
      }
    ],
    "win": {
      "target": "nsis",
      "icon": "icon.png"
    },
    "mac": {
      "target": "dmg",
      "icon": "icon.png",
      "category": "public.app-category.graphics-design"
    },
    "linux": {
      "target": "AppImage",
      "icon": "icon.png",
      "category": "Graphics"
    }
  },
  "dependencies": {
    "@google/genai": "^1.29.0",
    "@tailwindcss/vite": "^4.1.14",
    "@vitejs/plugin-react": "^5.0.4",
    "canvas-confetti": "^1.9.4",
    "clsx": "^2.1.1",
    "dotenv": "^17.2.3",
    "electron-updater": "^6.8.3",
    "express": "^4.21.2",
    "fabric": "^7.2.0",
    "imagetracerjs": "^1.2.6",
    "jspdf": "^4.2.1",
    "lucide-react": "^0.546.0",
    "motion": "^12.38.0",
    "paper": "^0.12.18",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "tailwind-merge": "^3.5.0",
    "vite": "^6.2.0"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^22.14.0",
    "autoprefixer": "^10.4.21",
    "electron": "^41.0.3",
    "electron-builder": "^26.8.1",
    "tailwindcss": "^4.1.14",
    "tsx": "^4.21.0",
    "typescript": "~5.8.2",
    "vite": "^6.2.0"
  }
}
